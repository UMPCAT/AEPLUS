<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aerolíneas Plus — Gestión de Comisiones | BNA</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:15px;scroll-behavior:smooth}
body{font-family:'Open Sans',Arial,sans-serif;background:#f0f4f8;color:#1a2a3a;min-height:100vh}

/* NAVBAR */
.topbar{background:#003366;height:4px;width:100%}
.navbar{background:#003366;padding:0 28px;display:flex;align-items:center;justify-content:space-between;height:62px;box-shadow:0 2px 10px rgba(0,0,0,.22)}
.brand{display:flex;align-items:center;gap:14px;text-decoration:none}
.bna-logo-box{background:#fff;color:#003366;font-weight:700;font-size:1rem;padding:5px 11px;border-radius:3px;line-height:1.2;letter-spacing:.03em}
.bna-logo-box small{display:block;font-size:.5rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase}
.nav-sep{width:1px;height:32px;background:rgba(255,255,255,.2)}
.nav-title{color:rgba(255,255,255,.72);font-size:.78rem;font-weight:300;letter-spacing:.06em;text-transform:uppercase}
.nav-tag{background:rgba(255,255,255,.1);color:rgba(255,255,255,.65);border:1px solid rgba(255,255,255,.18);font-size:.7rem;padding:3px 10px;border-radius:20px;letter-spacing:.04em}

/* HERO */
.hero{background:linear-gradient(135deg,#002855 0%,#004a99 100%);padding:34px 28px 30px;position:relative;overflow:hidden}
.hero::after{content:'';position:absolute;right:-40px;top:-40px;width:260px;height:260px;border-radius:50%;background:rgba(255,255,255,.04);pointer-events:none}
.hero-inner{max-width:820px;margin:0 auto;position:relative;z-index:1}
.hero-eye{display:flex;align-items:center;gap:7px;margin-bottom:9px}
.hero-dot{width:5px;height:5px;border-radius:50%;background:#f0a500}
.hero-eye span{color:rgba(255,255,255,.5);font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;font-weight:600}
.hero h1{color:#fff;font-size:1.55rem;font-weight:300;line-height:1.3;margin-bottom:5px}
.hero h1 strong{font-weight:700}
.hero p{color:rgba(255,255,255,.5);font-size:.82rem;font-weight:300}

/* MAIN */
.main{max-width:820px;margin:0 auto;padding:26px 18px 56px}

/* CARD */
.card{background:#fff;border-radius:5px;border:1px solid #d8e0ec;overflow:hidden;margin-bottom:18px}
.card-hd{background:#f5f8fc;border-bottom:1px solid #d8e0ec;padding:13px 20px;display:flex;align-items:center;gap:10px}
.card-hd-icon{width:26px;height:26px;background:#003366;border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.card-hd-icon svg{width:14px;height:14px;color:#fff}
.card-hd h2{font-size:.88rem;font-weight:700;color:#003366;letter-spacing:.01em}
.card-hd p{font-size:.72rem;color:#7a8a9a;margin-top:1px}
.card-bd{padding:20px}

/* FORM */
.search-row{display:flex;gap:12px;align-items:flex-end}
@media(max-width:500px){.search-row{flex-direction:column}}
.field{flex:1;display:flex;flex-direction:column;gap:5px}
label{font-size:.72rem;font-weight:700;color:#3a4e64;text-transform:uppercase;letter-spacing:.08em}
.iw{position:relative;display:flex;align-items:center}
.iw svg{position:absolute;left:10px;width:15px;height:15px;color:#a0aab4;pointer-events:none}
input[type=text]{width:100%;padding:10px 12px 10px 34px;border:1.5px solid #c4cedd;border-radius:4px;font-family:'Open Sans',Arial,sans-serif;font-size:.9rem;color:#1a2a3a;background:#fafcff;transition:border-color .16s,box-shadow .16s;outline:none}
input[type=text]:focus{border-color:#003366;background:#fff;box-shadow:0 0 0 3px rgba(0,51,102,.07)}
.hint{font-size:.68rem;color:#a0aab4}
.btn{padding:10px 22px;background:#003366;color:#fff;border:none;border-radius:4px;font-family:'Open Sans',Arial,sans-serif;font-size:.85rem;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:7px;transition:background .16s,transform .1s;white-space:nowrap;letter-spacing:.02em}
.btn:hover{background:#00509e}
.btn:active{transform:scale(.98)}
.btn:disabled{background:#a0aab4;cursor:not-allowed;transform:none}
.btn svg{width:15px;height:15px}

/* LOADER */
#loader{display:none;padding:28px;text-align:center}
.ring{width:34px;height:34px;border:3px solid #dde3ec;border-top-color:#003366;border-radius:50%;animation:spin .7s linear infinite;margin:0 auto 10px}
.ltxt{font-size:.76rem;color:#7a8a9a;letter-spacing:.05em}
@keyframes spin{to{transform:rotate(360deg)}}

/* MSG */
.msg{padding:14px 16px;border-radius:4px;display:flex;gap:10px;align-items:flex-start;font-size:.84rem;line-height:1.55}
.msg.error{background:#fff2f2;border:1px solid #f5c6c6;color:#7a1a1a}
.msg.warning{background:#fffbf0;border:1px solid #f0d070;color:#7a5500}
.msg svg{width:16px;height:16px;flex-shrink:0;margin-top:1px}

/* FICHA HEADER */
.fhdr{background:#003366;padding:16px 20px;display:flex;align-items:center;gap:13px}
.avatar{width:42px;height:42px;border-radius:50%;background:rgba(255,255,255,.14);border:2px solid rgba(255,255,255,.28);display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:700;color:#fff;flex-shrink:0}
.fname{color:#fff;font-size:1.05rem;font-weight:700;line-height:1.2}
.fcuil{color:rgba(255,255,255,.58);font-size:.74rem;margin-top:2px;letter-spacing:.04em}
.fbadge{margin-left:auto;background:rgba(255,255,255,.13);color:rgba(255,255,255,.82);font-size:.67rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:3px 9px;border-radius:20px;border:1px solid rgba(255,255,255,.2);white-space:nowrap}

/* NOVEDAD */
.nov-banner{padding:14px 20px;display:flex;align-items:center;gap:13px}
.nov-banner.BAJA{background:#fff0f0;border-top:3px solid #c0392b}
.nov-banner.AJUSTE{background:#fffbf0;border-top:3px solid #e67e22}
.nov-banner.SIN_NOVEDAD{background:#f0fff6;border-top:3px solid #1a7a4a}
.nov-banner.REVISAR{background:#f0f5ff;border-top:3px solid #003366}
.nov-ic{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.BAJA .nov-ic{background:#c0392b;color:#fff}
.AJUSTE .nov-ic{background:#e67e22;color:#fff}
.SIN_NOVEDAD .nov-ic{background:#1a7a4a;color:#fff}
.REVISAR .nov-ic{background:#003366;color:#fff}
.nov-ic svg{width:19px;height:19px}
.nov-lbl{font-size:.92rem;font-weight:700}
.BAJA .nov-lbl{color:#c0392b}
.AJUSTE .nov-lbl{color:#c0680a}
.SIN_NOVEDAD .nov-lbl{color:#1a7a4a}
.REVISAR .nov-lbl{color:#003366}
.nov-desc{font-size:.76rem;color:#5a6a7a;margin-top:2px;line-height:1.5}

/* DATOS GRID */
.dgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:0}
.ditem{padding:12px 16px;border-right:1px solid #edf0f5;border-bottom:1px solid #edf0f5}
.dlbl{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:#8a9ab0;margin-bottom:3px}
.dval{font-size:.84rem;color:#1a2a3a;font-weight:600;word-break:break-word}
.dval.mono{font-family:'Courier New',monospace;font-size:.78rem;background:#f4f6f9;padding:2px 5px;border-radius:3px;display:inline-block}
.dval.sm{font-size:.78rem;font-weight:400;color:#4a6a8a}
.craw{background:#f4f6f9;border-top:1px solid #edf0f5;padding:10px 16px;font-size:.76rem;color:#5a6a7a}
.craw strong{color:#003366}

/* PANEL DECISIÓN */
.dpanel{border-top:3px solid #003366;margin-top:0}
.dphdr{background:#f5f8fc;border-bottom:1px solid #d8e0ec;padding:11px 20px;font-size:.74rem;font-weight:700;color:#003366;letter-spacing:.07em;text-transform:uppercase;display:flex;align-items:center;gap:7px}
.dphdr svg{width:14px;height:14px}

/* FLOW STEPS */
.fbranch{display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid #edf0f5}
@media(max-width:520px){.fbranch{grid-template-columns:1fr}}
.fstep{padding:16px 18px;border-right:1px solid #edf0f5}
.fstep:last-child{border-right:none}
.fnum{width:20px;height:20px;background:#003366;color:#fff;border-radius:50%;font-size:.68rem;font-weight:700;display:flex;align-items:center;justify-content:center;margin-bottom:7px}
.ftitle{font-size:.8rem;font-weight:700;color:#1a2a3a;margin-bottom:4px}
.fdesc{font-size:.74rem;color:#5a6a7a;line-height:1.55}
.faction{margin-top:9px;display:inline-flex;align-items:center;gap:5px;background:#e8f0f8;color:#003366;padding:4px 10px;border-radius:3px;font-size:.7rem;font-weight:700;letter-spacing:.03em;text-transform:uppercase}
.faction svg{width:11px;height:11px}

/* TABLA DATOS BAJA */
.tbaja{width:100%;border-collapse:collapse;font-size:.8rem}
.tbaja th{background:#f0f4f8;color:#003366;font-size:.68rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:8px 14px;text-align:left;border-bottom:1px solid #d8e0ec}
.tbaja td{padding:9px 14px;border-bottom:1px solid #edf0f5;color:#1a2a3a}
.tbaja tr:last-child td{border-bottom:none}
.tbaja .tc{font-weight:600;color:#3a4e64;width:42%}

/* MULTI */
.mhdr{background:#003366;color:#fff;padding:11px 20px;font-size:.8rem;display:flex;align-items:center;gap:9px;border-radius:5px 5px 0 0}
.mcnt{background:#f0a500;color:#003366;font-weight:700;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.78rem;flex-shrink:0}
.mwrap .card{border-radius:0;border-top:none}
.mwrap .card:last-child{border-radius:0 0 5px 5px}

/* FOOTER */
footer{background:#003366;color:rgba(255,255,255,.4);text-align:center;padding:16px;font-size:.7rem;letter-spacing:.05em;margin-top:32px}
</style>
</head>
<body>

<div class="topbar"></div>
<nav class="navbar">
  <div class="brand">
    <div class="bna-logo-box">BNA<small>Banco Nación</small></div>
    <div class="nav-sep"></div>
    <span class="nav-title">Aerolíneas Plus</span>
  </div>
  <span class="nav-tag">Uso interno · NOA Oeste</span>
</nav>

<div class="hero">
  <div class="hero-inner">
    <div class="hero-eye"><div class="hero-dot"></div><span>Gestión de comisiones</span></div>
    <h1><strong>Programa Aerolíneas Plus</strong><br>Consulta de titulares y novedades</h1>
    <p>Ingresá el CUIL/CUIT del cliente para verificar su situación y determinar las acciones a seguir.</p>
  </div>
</div>

<div class="main">

  <!-- BÚSQUEDA -->
  <div class="card">
    <div class="card-hd">
      <div class="card-hd-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </div>
      <div>
        <h2>Consultar titular</h2>
        <p>Búsqueda en bases Visa, Mastercard y Reporte de Aceptación</p>
      </div>
    </div>
    <div class="card-bd">
      <div class="search-row">
        <div class="field">
          <label for="cuil">CUIL / CUIT del titular</label>
          <div class="iw">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <input type="text" id="cuil" placeholder="Ej: 27236235470" maxlength="13"
              oninput="this.value=this.value.replace(/\D/g,'')"
              onkeydown="if(event.key==='Enter')buscar()">
          </div>
          <span class="hint">Sin guiones ni espacios · 10 u 11 dígitos</span>
        </div>
        <button class="btn" onclick="buscar()" id="btnB">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          Consultar
        </button>
      </div>
      <div id="loader"><div class="ring"></div><p class="ltxt">Consultando base de datos…</p></div>
    </div>
  </div>

  <div id="res"></div>
</div>

<footer>Banco de la Nación Argentina &nbsp;·&nbsp; Gerencia Zonal NOA Oeste &nbsp;·&nbsp; Sistema de uso interno exclusivo</footer>

<script>
// ⚠️ REEMPLAZAR con la URL de tu Google Apps Script Web App
const GAS_URL = "https://github.com/UMPCAT/AEPLUS.git";

function buscar() {
  const cuil = (document.getElementById('cuil').value || '').trim();
  const out = document.getElementById('res');
  if (!cuil) { out.innerHTML = msj('error','Campo requerido','Ingresá el CUIL/CUIT del titular.'); return; }
  if (cuil.length < 10) { out.innerHTML = msj('error','CUIL inválido','El CUIL/CUIT debe tener al menos 10 dígitos.'); return; }
  out.innerHTML = '';
  tog(true);
  const cb = 'cb_' + Date.now();
  const s  = document.createElement('script');
  // Enviamos tarjeta vacía → el backend trae TODOS los registros del CUIL
  s.src = GAS_URL + '?cuil=' + encodeURIComponent(cuil) + '&tarjeta=&callback=' + cb;
  const t = setTimeout(() => {
    tog(false);
    out.innerHTML = msj('error','Sin respuesta','No se pudo conectar. Verificá tu conexión e intentá nuevamente.');
    limpiar(s, cb);
  }, 22000);
  window[cb] = function(data) {
    clearTimeout(t); tog(false); limpiar(s, cb); render(data, cuil);
  };
  document.body.appendChild(s);
}

function limpiar(s, cb) { if (s.parentNode) document.body.removeChild(s); delete window[cb]; }
function tog(on) { document.getElementById('loader').style.display = on ? 'block' : 'none'; document.getElementById('btnB').disabled = on; }

function render(data, cuil) {
  const out = document.getElementById('res');
  if (!data.ok && data.error) { out.innerHTML = msj('error','Error',e(data.error)); return; }
  if (!data.ok && data.sinDatos) {
    out.innerHTML = msj('warning','Sin resultados','No se encontraron registros para el CUIL/CUIT <strong>' + e(cuil) + '</strong> en ninguna de las bases del programa.');
    return;
  }
  let h = '';
  if (data.total > 1) {
    h += '<div class="mhdr"><div class="mcnt">' + data.total + '</div><span>Registros encontrados para CUIL/CUIT ' + e(cuil) + '</span></div><div class="mwrap">';
  }
  for (const r of data.resultados) h += ficha(r);
  if (data.total > 1) h += '</div>';
  out.innerHTML = h;
}

function ficha(r) {
  const nov = r.novedad;
  const ini = ((r.nombre||'')[0]||'').toUpperCase() + ((r.apellido||'')[0]||'').toUpperCase() || '??';

  const campos = [
    ['CUIL/CUIT', r.cuil, 'mono'],
    ['Nombre completo', (r.nombre||'') + ' ' + (r.apellido||''), ''],
    ['Entidad', r.entidad, ''],
    ['Tipo de tarjeta', r.tipoTarjeta, ''],
    ['TC últimos dígitos', r.ultimosTC, 'mono'],
    ['Email', r.email, 'sm'],
    ['Fecha aceptación', r.fechaAcept, ''],
    ['Aceptación', fb(r.aceptacion), ''],
    ['Empleado BNA', fb(r.empleado), ''],
    ['Convenios', r.convenios, ''],
  ].filter(([,v]) => v && v.trim() && v !== '—');

  const grid = campos.map(([l,v,c]) =>
    '<div class="ditem"><div class="dlbl">'+e(l)+'</div><div class="dval '+c+'">'+e(v)+'</div></div>'
  ).join('');

  const raw = (r.condicion && r.condicion !== '—' && r.condicion !== 'Aceptado')
    ? '<div class="craw"><strong>Condición registrada:</strong> ' + e(r.condicion) + '</div>' : '';

  return `
  <div class="card">
    <div class="fhdr">
      <div class="avatar">${ini}</div>
      <div><div class="fname">${e(r.apellido)}, ${e(r.nombre)}</div><div class="fcuil">CUIL/CUIT ${e(r.cuil)}</div></div>
      <span class="fbadge">${e(r.fuente||'')}</span>
    </div>
    <div class="nov-banner ${nov.tipo}">
      <div class="nov-ic">${nic(nov.tipo)}</div>
      <div><div class="nov-lbl">${e(nov.label)}</div><div class="nov-desc">${e(nov.detalle)}</div></div>
    </div>
    <div class="dgrid">${grid}</div>
    ${raw}
    ${decision(r, nov)}
  </div>`;
}

function decision(r, nov) {
  if (nov.tipo === 'SIN_NOVEDAD') {
    return `
    <div class="dpanel">
      <div class="dphdr">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        Titular aceptó términos y condiciones — acciones a seguir
      </div>
      <div class="fbranch">
        <div class="fstep">
          <div class="fnum">1</div>
          <div class="ftitle">Confirmar fecha de aceptación</div>
          <div class="fdesc">Registrar que el titular aceptó los términos y condiciones del programa en la siguiente fecha:</div>
          <div class="faction">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            ${e(r.fechaAcept || 'Sin fecha registrada')}
          </div>
        </div>
        <div class="fstep">
          <div class="fnum">2</div>
          <div class="ftitle">Notificar al cliente por email</div>
          <div class="fdesc">Informar al cliente vía mail registrado que aceptó T&amp;C y que puede solicitar la baja del programa para que no se le cobre la próxima renovación.</div>
          <div class="faction">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            ${r.email && r.email !== '—' ? e(r.email) : 'Sin email registrado'}
          </div>
        </div>
      </div>
    </div>`;
  }

  // BAJA / AJUSTE / REVISAR
  return `
  <div class="dpanel">
    <div class="dphdr">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      No aceptó términos — gestionar baja y ajuste de comisión
    </div>
    <div class="fbranch">
      <div class="fstep">
        <div class="fnum">1</div>
        <div class="ftitle">Verificar y gestionar baja</div>
        <div class="fdesc">Confirmar la baja del programa en el sistema y registrar la modificación del grupo afindad del cliente.</div>
        <div class="faction">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          Procesar baja en sistema
        </div>
      </div>
      <div class="fstep">
        <div class="fnum">2</div>
        <div class="ftitle">Armar archivo y enviar ajuste</div>
        <div class="fdesc">Generar el archivo de cobranzas con los datos del cliente y enviar a Gestión de Ajuste.</div>
        <div class="faction">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Generar archivo
        </div>
      </div>
    </div>
    <table class="tbaja">
      <thead><tr><th colspan="2">Datos para archivo de cobranzas y ajuste</th></tr></thead>
      <tbody>
        <tr><td class="tc">Entidad</td><td>${e(r.entidad||'—')}</td></tr>
        <tr><td class="tc">Sucursal TC (3 dígitos)</td><td>—</td></tr>
        <tr><td class="tc">Cuenta con dígito verificador</td><td>${e(r.cuil||'—')}</td></tr>
        <tr><td class="tc">Grupo / Cartera</td><td>${e(r.convenios||'—')}</td></tr>
        <tr><td class="tc">Tipo tarjeta</td><td>${e(r.tipoTarjeta||'—')}</td></tr>
        <tr><td class="tc">TC últimos dígitos</td><td>${e(r.ultimosTC||'—')}</td></tr>
        <tr><td class="tc">Fecha de baja</td><td>${e(r.fechaAcept||'—')}</td></tr>
        <tr><td class="tc">Email para notificación</td><td>${e(r.email && r.email!=='—' ? r.email : 'Sin registro')}</td></tr>
      </tbody>
    </table>
  </div>`;
}

function fb(v) {
  if (!v||v==='—') return '—';
  const u=v.toUpperCase();
  if(u==='S'||u==='SI'||u==='SÍ') return 'Sí';
  if(u==='N'||u==='NO') return 'No';
  return v;
}

function nic(t) {
  const s = {
    BAJA: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>',
    AJUSTE: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4z"/></svg>',
    SIN_NOVEDAD: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>',
  };
  return s[t] || s.AJUSTE;
}

function msj(tipo, tit, txt) {
  const ic = tipo==='error'
    ? '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>'
    : '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>';
  return `<div class="msg ${tipo}">${ic}<div><strong>${e(tit)}:</strong> ${txt}</div></div>`;
}

function e(s) {
  if(!s) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
